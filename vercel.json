{
  "crons": [
    {
      "path": "/api/cron/cleanup-orders",
      "schedule": "0 0 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path((?!www\\.).*)?",
      "has": [
        {
          "type": "host",
          "value": "pcccc.cc"
        }
      ],
      "destination": "https://www.pcccc.cc/:path*",
      "permanent": false
    }
  ]
}
